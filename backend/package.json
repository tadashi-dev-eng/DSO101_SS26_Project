{
  "name": "backend",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "generate": "prisma generate",
    "build": "npm run generate && node --trace-warnings ./node_modules/.bin/tsc --pretty false",
    "start": "node dist/index.js",
    "test": "NODE_ENV=test npx vitest run --reporter=verbose",
    "coverage": "npx vitest run --coverage --reporter=verbose",
    "security": "npx snyk test --severity-threshold=high"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.14",
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "hono": "^4.12.16",
    "mongodb": "^7.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "@vitest/coverage-v8": "^1.6.1",
    "prisma": "^6.19.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^1.5.5"
  },
  "version": "1.0.0",
  "description": "``` npm install npm run dev ```",
  "main": "index.js",
  "author": "",
  "license": "ISC"
}
